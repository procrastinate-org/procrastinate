{
  extends: [
    'config:recommended',
    ':enablePreCommit',
    'helpers:pinGitHubActionDigests',
  ],
  schedule: [
    'before 4am on Saturday',
  ],
  labels: [
    'PR type: dependencies 🤖',
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  packageRules: [
    {
      groupName: 'all dependencies',
      groupSlug: 'all',
      matchPackageNames: [
        '*',
      ],
    },
    {
      // setuptools 81 removed pkg_resources, which migra -> schemainspect
      // still imports. Keep it below 81 (matching the pin in pyproject.toml)
      matchPackageNames: [
        'setuptools',
      ],
      matchUpdateTypes: [
        'major',
      ],
      enabled: false,
    },
  ],
  automerge: true,
}
